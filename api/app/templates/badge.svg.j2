<svg xmlns="http://www.w3.org/2000/svg" width="140" height="20">
  <linearGradient id="s" x2="0" y2="100%">
    <stop offset="0" stop-color="#bbb" stop-opacity=".1"/>
    <stop offset="1" stop-opacity=".1"/>
  </linearGradient>
  <rect rx="3" width="140" height="20" fill="#555"/>
  <rect rx="3" x="80" width="60" height="20" fill="{{ color }}"/>
  <rect rx="3" width="140" height="20" fill="url(#s)"/>
  <g fill="#fff" text-anchor="middle" font-family="DejaVu Sans,Verdana,Geneva,sans-serif" font-size="110">
    <text x="405" y="150" fill="#010101" fill-opacity=".3" transform="scale(.1)">CAPScore</text>
    <text x="405" y="140" transform="scale(.1)">CAPScore</text>
    <text x="1095" y="150" fill="#010101" fill-opacity=".3" transform="scale(.1)">{{ score }}/100</text>
    <text x="1095" y="140" transform="scale(.1)">{{ score }}/100</text>
  </g>
</svg>
